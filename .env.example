# Copy to .env and adjust values.

# JSON array of meters. Each object requires: deviceCode, name, site, host, port, unitId
# Example (single line or use a .env file that supports multiline with quotes):
# DEVICES=[{"deviceCode":"M1","name":"Main incomer","site":"plant-a","host":"192.168.1.50","port":502,"unitId":1}]
DEVICES=[]

# Local MQTT broker (same server)
MQTT_URL=mqtt://127.0.0.1:1883

# Optional: required when the broker has allow_anonymous false (e.g. Mosquitto + passwd file)
# MQTT_USERNAME=powerlogic_user
# MQTT_PASSWORD=

# Polling and Modbus
POLL_INTERVAL_MS=5000
MODBUS_TIMEOUT_MS=3000

# Phase voltages must all be below 20V for this long before an outage event is published
OUTAGE_CONFIRM_MS=30000

# trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Log each successful poll as JSON (set to false | 0 | off to disable)
LOG_METER_READINGS=true
