# Copy to `.env` and fill in values. Do not commit `.env` (it is gitignored).

# -----------------------------------------------------------------------------
# Meters (Supabase only)
# -----------------------------------------------------------------------------
#
# All meters are read from Postgres table `public.devices` (rows with `enabled = true`).
# Apply `sql/supabase_devices.sql` in the Supabase SQL editor, then seed rows.
#
# Use the service role key only on the gateway server — never in browsers or client apps.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Optional: table name if not `devices`
# SUPABASE_DEVICES_TABLE=devices
#
# Deprecated alias (still read if `SUPABASE_DEVICES_TABLE` is unset):
# SUPABASE_GATEWAY_DEVICES_TABLE=devices

# -----------------------------------------------------------------------------
# MQTT
# -----------------------------------------------------------------------------
MQTT_URL=mqtt://127.0.0.1:1883

# When the broker disallows anonymous access (e.g. Mosquitto + password file):
# MQTT_USERNAME=
# MQTT_PASSWORD=

# -----------------------------------------------------------------------------
# Polling and Modbus
# -----------------------------------------------------------------------------
POLL_INTERVAL_MS=5000
MODBUS_TIMEOUT_MS=3000

# Delay before retrying Modbus after a failed read (ms). Independent of POLL_INTERVAL_MS.
MODBUS_RETRY_MS=3000

# All phase voltages must stay below the outage threshold (see code) for this long before an outage event is published.
OUTAGE_CONFIRM_MS=30000

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Full JSON telemetry every poll (false | 0 | off = compact readingsSummary only)
LOG_METER_READINGS=true
